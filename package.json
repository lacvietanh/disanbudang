    "@vueuse/nuxt": "^14.3.0",
    "better-sqlite3": "^12.10.0",
    "leaflet": "^1.9.4",
    "nuxt": "^4.4.2",
    "nuxt-security": "^2.5.1",
    "pinia": "^2.3.0",
